# Configuración por defecto para docker-compose (local, red bridge).
# Todo es sobrescribible: nada hardcodeado en el código.

# CSV que emite el Productor (data/pedidos_pequeño.csv | _mediano | _grande)
PROD_CSV=data/pedidos_pequeño.csv

# Puertos gRPC
BROKER_PUERTO=50051
GW_PUERTO=50040
DN1_PUERTO=50061
DN2_PUERTO=50062
DN3_PUERTO=50063

# Tiempos (Fase 5, gossip, afinidad)
BROKER_GRACE=15s
GW_TTL=60s
DN_GOSSIP_MIN=3s
DN_GOSSIP_MAX=7s

# Cliente
CLI_PEDIDOS=2
CLI_DELAY=6s

# Productor: espera entre grupos de eventos
PROD_MIN=1s
PROD_MAX=3s
PROD_DELAY=5s

# --- Despliegue en 4 VMs (docker-compose-vm{1..4}.yml, network_mode host) ---
# Reemplazar por las IPs reales de cada máquina en la evaluación.
IP_MV1=127.0.0.1
IP_MV2=127.0.0.1
IP_MV3=127.0.0.1
IP_MV4=127.0.0.1
